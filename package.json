{
  "name": "side-note",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "esbuild extension/src/sidepanel.js --bundle --platform=browser --format=iife --sourcemap --outfile=extension/sidepanel.js",
    "build:prod": "esbuild extension/src/sidepanel.js --bundle --platform=browser --format=iife --minify --outfile=extension/sidepanel.js",
    "prepack": "npm run build:prod && rm -f extension/*.map extension/src/*.js",
    "pack": "cd extension && zip -r ../side-note.zip . -x '*.map' -x 'src/*'",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:install:browsers": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers npx playwright install chromium",
    "test:install:browsers:mirror": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers PLAYWRIGHT_DOWNLOAD_HOST=https://npmmirror.com/mirrors/playwright npx playwright install chromium",
    "test:run:system-chrome": "PW_USE_SYSTEM_CHROME=1 npx playwright test",
    "test:run:system-edge": "PW_USE_SYSTEM_CHROME=1 PW_CHROME_CHANNEL=msedge npx playwright test",
    "test:run:i18n-static": "PW_USE_SYSTEM_CHROME=1 npx playwright test tests/i18n.static.spec.js --workers=1"
  },
  "dependencies": {
    "@codemirror/commands": "^6.3.3",
    "@codemirror/lang-markdown": "^6.2.5",
    "@codemirror/language": "^6.9.2",
    "@codemirror/language-data": "^6.4.1",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.24.0",
    "@lezer/highlight": "^1.2.0",
    "codemirror": "^6.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "@playwright/test": "^1.41.0"
  }
}
